# ── Obrigatórias ─────────────────────────────────────────────────────────────

# Connection string do seu banco Neon (https://neon.tech, plano grátis).
# No painel do projeto: botão "Connect" -> copie a connection string.
DATABASE_URL=postgresql://usuario:senha@ep-xxxxx.regiao.aws.neon.tech/neondb?sslmode=require

# Segredo das sessões de login. Gere um valor aleatório com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=troque-por-um-valor-aleatorio-longo

# ── Opcionais: integração com Telegram ───────────────────────────────────────
# Permite registrar gastos mandando mensagem para um bot seu.
# Veja o passo a passo no README. Sem estas variáveis o app funciona normalmente.

# Token do bot, fornecido pelo @BotFather
TELEGRAM_BOT_TOKEN=

# Segredo do webhook (outro valor aleatório, gerado por você)
TELEGRAM_WEBHOOK_SECRET=

# Login (do app) que recebe os lançamentos enviados pelo bot
TELEGRAM_USER_LOGIN=

# ID do seu chat no Telegram (o bot te informa no primeiro contato)
TELEGRAM_CHAT_ID=

# ── Opcional: mês automático ─────────────────────────────────────────────────
# Protege o endpoint chamado pelo Vercel Cron que inicia o mês novo sozinho.
# Gere outro valor aleatório. Sem ele, o cron responde 401 (e nada mais acontece).
CRON_SECRET=
